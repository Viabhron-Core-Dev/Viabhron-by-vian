{
  "entities": {
    "UserSession": {
      "title": "User Session",
      "description": "Stores user-specific app state and sessions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "activeTabId": { "type": "string", "description": "The ID of the currently active tab." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "activeTabId"]
    },
    "Tab": {
      "title": "Tab",
      "description": "A single browser-like tab session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "shelved", "archived"] },
        "agentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "type", "status"]
    },
    "Chat": {
      "title": "Celestial Chat",
      "description": "A chat session in the Vaa client.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["direct", "council", "individual", "workflow", "debate", "agent", "gmail", "sentinel"] },
        "filterCategory": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "updatedAt"]
    },
    "Agent": {
      "title": "Sovereign Agent",
      "description": "An AI agent within the OS.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "role": { "type": "string", "enum": ["head", "executive", "contractor", "consultant", "specialized"] },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "error"] },
        "color": { "type": "string" },
        "isStaff": { "type": "boolean", "description": "Whether the agent is a persistent staff member." },
        "isAnchor": { "type": "boolean", "description": "Whether the agent is the Sovereign Anchor (Tiny LLM)." },
        "isCloudManager": { "type": "boolean", "description": "Whether the agent is the primary Cloud Manager (Resident Head Agent)." },
        "isResident": { "type": "boolean", "description": "Whether the agent is a resident of the private cloud." },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "role", "provider", "model", "status"]
    },
    "SovereignSkill": {
      "title": "Sovereign Skill",
      "description": "A self-built capability generated by the OS agents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "code": { "type": "string", "description": "The Markdown or TypeScript code for the skill." },
        "type": { "type": "string", "enum": ["script", "tool", "workflow"] },
        "status": { "type": "string", "enum": ["draft", "ratified", "archived"] },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "code", "type", "status", "createdAt"]
    },
    "HeartbeatLog": {
      "title": "Heartbeat Log",
      "description": "Autonomous 24/7 system activity and self-improvement logs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["pulse", "optimization", "audit", "hatch"] },
        "content": { "type": "string" },
        "impact": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "content", "timestamp"]
    },
    "Spore": {
      "title": "Spore",
      "description": "An expeditionary intelligence unit on external storage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mission": { "type": "string", "description": "The specific task for this Spore (e.g., Video Editing)." },
        "subManagerId": { "type": "string", "description": "The ID of the specialized Resident Agent managing this Spore." },
        "status": { "type": "string", "enum": ["active", "quarantined", "harvested", "incinerated"] },
        "lastSync": { "type": "string", "format": "date-time" },
        "storageType": { "type": "string", "enum": ["USB", "SD", "ExternalHDD", "Phone"] }
      },
      "required": ["id", "name", "mission"]
    },
    "BlackBox": {
      "title": "BlackBox",
      "description": "A physical emergency backup of the Sovereign OS.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lastFold": { "type": "string", "format": "date-time" },
        "version": { "type": "string", "description": "The OS version/Epoch at the time of backup." },
        "integrityStatus": { "type": "string", "enum": ["verified", "stale", "corrupted"] },
        "encryptionShardId": { "type": "string", "description": "Reference to the physical encryption token ID." }
      },
      "required": ["id", "lastFold"]
    },
    "Secret": {
      "title": "Sovereign Secret",
      "description": "An encrypted API key or sensitive credential.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "description": "A human-readable name for the secret." },
        "value": { "type": "string", "description": "The actual secret value (encrypted or masked)." },
        "type": { "type": "string", "enum": ["api_key", "oauth_token", "other"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "label", "value", "type", "createdAt"]
    },
    "FilterConfig": {
      "title": "Filter Configuration",
      "description": "User's chat filter preferences.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "integer" }
      },
      "required": ["id", "label", "active", "order"]
    },
    "Notification": {
      "title": "System Notification",
      "description": "A notification for the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["security", "info", "warning", "error", "system"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "message", "type", "read", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant", "system"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role", "content", "timestamp"]
    },
    "Memory": {
      "title": "Memory Fragment",
      "description": "A learned insight or preference for the AI Second Brain.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["preference", "fact", "style", "goal", "resonance"] },
        "content": { "type": "string" },
        "strength": { "type": "integer", "minimum": 1, "maximum": 10 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "content", "strength", "timestamp"]
    },
    "VaultPointer": {
      "title": "Vault Pointer",
      "description": "A reference to an encrypted, compressed file stored in Google Drive.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "gdriveId": { "type": "string" },
        "encryptionHash": { "type": "string" },
        "size": { "type": "integer" },
        "compressed": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "path", "gdriveId", "encryptionHash", "size", "compressed", "timestamp"]
    },
    "AgentLog": {
      "title": "Agent Log",
      "description": "Execution logs for background agents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["command", "output", "error", "system", "thought"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "agentId": { "type": "string" }
      },
      "required": ["id", "type", "content", "timestamp"]
    },
    "SentinelConfig": {
      "title": "Sentinel Configuration",
      "description": "Settings for the Sentinel Guardian antivirus.",
      "type": "object",
      "properties": {
        "scanInterval": { "type": "integer", "minimum": 1, "maximum": 24 },
        "scanDepth": { "type": "string", "enum": ["quick", "deep", "paranoid"] },
        "virusTotalApiKey": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["scanInterval", "scanDepth", "active"]
    },
    "ScanResult": {
      "title": "Scan Result",
      "description": "Results of a file integrity scan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "status": { "type": "string", "enum": ["clean", "suspicious", "malicious"] },
        "threatLevel": { "type": "integer", "minimum": 0, "maximum": 100 },
        "timestamp": { "type": "string", "format": "date-time" },
        "engine": { "type": "string" }
      },
      "required": ["id", "fileName", "status", "threatLevel", "timestamp", "engine"]
    },
    "SecurityRule": {
      "title": "Security Rule / Sovereign Procedure",
      "description": "A natural language rule or procedure for the agent company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "naturalLanguage": { "type": "string", "description": "The rule in plain English." },
        "technicalBlock": { "type": "string", "description": "The technical implementation or regex." },
        "type": { "type": "string", "enum": ["security", "operational", "fiscal"] },
        "urgencyLevel": { "type": "string", "enum": ["standard", "critical"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "naturalLanguage", "type", "urgencyLevel", "active", "createdAt"]
    },
    "TokenGovernance": {
      "title": "Token Governance",
      "description": "Settings for managing OS-wide and extension-specific token usage.",
      "type": "object",
      "properties": {
        "globalMasterSlider": { "type": "integer", "minimum": 0, "maximum": 100 },
        "nexusSlider": { "type": "integer", "minimum": 0, "maximum": 100 },
        "emergencyBreakerEnabled": { "type": "boolean" },
        "dailyTokenLimit": { "type": "integer" },
        "currentDailyUsage": { "type": "integer" },
        "gracefulDegradationEnabled": { "type": "boolean" },
        "priorityModuleIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["globalMasterSlider", "nexusSlider", "emergencyBreakerEnabled", "dailyTokenLimit", "currentDailyUsage", "gracefulDegradationEnabled"]
    },
    "NexusSettings": {
      "title": "Nexus Settings",
      "description": "Configuration for the Viabhron Nexus private library.",
      "type": "object",
      "properties": {
        "isEnabled": { "type": "boolean" },
        "isPrivate": { "type": "boolean" },
        "allowedAgentIds": { "type": "array", "items": { "type": "string" } },
        "tokenUsageSlider": { "type": "integer", "minimum": 0, "maximum": 100 },
        "autoForkEnabled": { "type": "boolean" },
        "autonomyMandateEnabled": { "type": "boolean" }
      },
      "required": ["isEnabled", "isPrivate", "allowedAgentIds", "tokenUsageSlider", "autoForkEnabled", "autonomyMandateEnabled"]
    },
    "X402Config": {
      "title": "X402 Payment Gateway Config",
      "description": "Settings for the x402 autonomous payment system.",
      "type": "object",
      "properties": {
        "dailyLimit": { "type": "number", "minimum": 0 },
        "currentSpending": { "type": "number" },
        "provider": { "type": "string", "enum": ["coinbase", "nodit", "stripe"] },
        "active": { "type": "boolean" },
        "lastResetAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dailyLimit", "currentSpending", "provider", "active"]
    },
    "X402Transaction": {
      "title": "X402 Transaction",
      "description": "A record of an autonomous payment for AI services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "service": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "agentId": { "type": "string" }
      },
      "required": ["id", "amount", "currency", "service", "status", "timestamp"]
    },
    "SovereignIdentity": {
      "title": "Sovereign Identity (8004)",
      "description": "On-chain digital passport for an agent or user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "did": { "type": "string", "description": "Decentralized Identifier" },
        "chain": { "type": "string", "enum": ["tron", "bnb", "ethereum", "base"] },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["unverified", "verified", "revoked"] },
        "issuedAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "did", "chain", "address", "status"]
    },
    "MultiChainConfig": {
      "title": "Multi-Chain Configuration",
      "description": "Settings for blockchain bridges and identity registrar.",
      "type": "object",
      "properties": {
        "defaultChain": { "type": "string" },
        "enabledChains": { "type": "array", "items": { "type": "string" } },
        "registrarAgentId": { "type": "string" },
        "autoVerify": { "type": "boolean" }
      },
      "required": ["defaultChain", "enabledChains", "registrarAgentId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserSession",
      "description": "User profile and global state."
    },
    "/users/{userId}/tabs/{tabId}": {
      "schema": "Tab",
      "description": "Tabs belonging to a specific user."
    },
    "/users/{userId}/tabs/{tabId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific tab."
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": "Memory",
      "description": "The Soul Core: Learned insights and user resonance."
    },
    "/users/{userId}/vault/{pointerId}": {
      "schema": "VaultPointer",
      "description": "The Neural Archive: Pointers to deep storage in GDrive."
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "AgentLog",
      "description": "Rolling execution logs for agents."
    },
    "/users/{userId}/sentinel/config": {
      "schema": "SentinelConfig",
      "description": "Sentinel Guardian settings."
    },
    "/users/{userId}/sentinel/results/{resultId}": {
      "schema": "ScanResult",
      "description": "Threat detection history."
    },
    "/users/{userId}/security/rules/{ruleId}": {
      "schema": "SecurityRule",
      "description": "The Articles of Incorporation: Natural language rules for the agent company."
    },
    "/users/{userId}/settings/token_governance": {
      "schema": "TokenGovernance",
      "description": "OS-wide token management settings."
    },
    "/users/{userId}/settings/nexus": {
      "schema": "NexusSettings",
      "description": "Viabhron Nexus configuration."
    },
    "/users/{userId}/fiscal/x402/config": {
      "schema": "X402Config",
      "description": "x402 Payment Gateway settings."
    },
    "/users/{userId}/fiscal/x402/transactions/{transactionId}": {
      "schema": "X402Transaction",
      "description": "Autonomous billing history."
    },
    "/users/{userId}/security/identity/8004/{identityId}": {
      "schema": "SovereignIdentity",
      "description": "On-chain agent passports."
    },
    "/users/{userId}/security/identity/config": {
      "schema": "MultiChainConfig",
      "description": "Identity registrar and chain settings."
    },
    "/users/{userId}/vaa/chats/{chatId}": {
      "schema": "Chat",
      "description": "Vaa client chat sessions."
    },
    "/users/{userId}/vaa/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a Vaa chat."
    },
    "/users/{userId}/vaa/filters/{filterId}": {
      "schema": "FilterConfig",
      "description": "Vaa client filter preferences."
    },
    "/users/{userId}/secrets/{secretId}": {
      "schema": "Secret",
      "description": "Encrypted API keys and credentials."
    },
    "/users/{userId}/agents/{agentId}": {
      "schema": "Agent",
      "description": "Sovereign agents belonging to the user."
    },
    "/users/{userId}/skills/{skillId}": {
      "schema": "SovereignSkill",
      "description": "Self-built skills and capabilities."
    },
    "/users/{userId}/heartbeat/{logId}": {
      "schema": "HeartbeatLog",
      "description": "Autonomous 24/7 system pulses."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System-wide notifications."
    }
  }
}
